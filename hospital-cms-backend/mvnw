#!/bin/sh
# Maven Wrapper script – downloads Maven if not present
# Generated for hospital-cms project

if [ -z "$JAVA_HOME" ]; then
  JAVA_HOME=$(java -XshowSettings:all -version 2>&1 \
    | grep 'java.home' | awk '{print $3}' | head -1)
fi

MAVEN_VERSION="3.9.6"
MAVEN_HOME="${HOME}/.m2/wrapper/dists/apache-maven-${MAVEN_VERSION}"
MAVEN_URL="https://downloads.apache.org/maven/maven-3/${MAVEN_VERSION}/binaries/apache-maven-${MAVEN_VERSION}-bin.tar.gz"

if [ ! -d "$MAVEN_HOME" ]; then
  echo "Downloading Maven ${MAVEN_VERSION}..."
  mkdir -p "$MAVEN_HOME"
  curl -fsSL "$MAVEN_URL" | tar -xz -C "$MAVEN_HOME" --strip-components=1
fi

exec "${MAVEN_HOME}/bin/mvn" "$@"
